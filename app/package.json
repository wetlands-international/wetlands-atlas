    "nuqs": "2.4.1",
    "openapi-fetch": "0.13.7",
    "openapi-react-query": "0.4.1",
    "payload": "3.76.1",
    "payload-oapi": "0.2.5",
    "postcss": "8.5.3",
    "postprocessing": "6.37.3",
    "qs-esm": "7.0.2",
    "query-string": "9.2.2",
    "react": "19.0.1",
    "react-dom": "19.0.1",
    "react-hook-form": "7.64.0",
    "react-icons": "5.5.0",
    "react-map-gl": "8.0.4",
