    "@react-three/fiber": "^9.1.2",
    "@react-three/postprocessing": "3.0.4",
    "@t3-oss/env-nextjs": "0.12.0",
    "@tailwindcss/postcss": "4.1.3",
    "@tanstack/react-query": "5.75.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "17.0.0",
    "drizzle-orm": "0.44.7",
    "embla-carousel-react": "8.6.0",
    "graphql": "^16.8.1",
